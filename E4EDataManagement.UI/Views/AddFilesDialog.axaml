<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:E4EDataManagement.UI.ViewModels"
        x:Class="E4EDataManagement.UI.Views.AddFilesDialog"
        x:DataType="vm:AddFilesViewModel"
        Title="Add Files"
        Width="500" Height="420"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="16">

        <!-- File list controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
            <Button Content="Add Files…" Name="AddFilesButton" />
            <Button Content="Remove"
                    Command="{Binding RemoveSelectedCommand}"
                    IsEnabled="{Binding CanRemove}" />
        </StackPanel>

        <!-- File list -->
        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                CornerRadius="4"
                Margin="0,0,0,10">
            <ListBox ItemsSource="{Binding Files}"
                     SelectedItem="{Binding SelectedFile}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Border>

        <!-- Options -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*"
              RowDefinitions="Auto,Auto"
              Margin="0,0,0,10">

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Destination subfolder:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,8" />
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding Destination}"
                     Watermark="(optional, e.g. raw)"
                     Margin="0,0,0,8" />

            <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                      IsChecked="{Binding IsReadme}"
                      Content="Dataset-level README (not mission-level)" />
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel"
                    Name="CancelButton"
                    Width="80" />
            <Button Content="Add"
                    Name="OkButton"
                    Width="80"
                    IsEnabled="{Binding CanConfirm}"
                    IsDefault="True" />
        </StackPanel>

    </Grid>
</Window>
